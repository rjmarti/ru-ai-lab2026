@page
@model SsoAdmin.Web.Pages.Usuarios.IndexModel
@{ ViewData["Title"] = "Usuarios"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Usuarios</h2>
    <a asp-page="Create" class="btn btn-primary">+ Nuevo usuario</a>
</div>

@if (TempData["Mensaje"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>#</th><th>Nombre</th><th>Estado</th><th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model.Usuarios)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Name</td>
                <td>
                    @if (u.IsActive)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td>
                    <a asp-page="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    @if (u.IsActive)
                    {
                        <form method="post" asp-page-handler="Baja" asp-route-id="@u.Id" class="d-inline"
                              onsubmit="return confirm('¿Dar de baja a @u.Name?')">
                            <button type="submit" class="btn btn-sm btn-warning">Dar de baja</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
