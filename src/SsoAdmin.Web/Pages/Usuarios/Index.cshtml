@page
@model SsoAdmin.Web.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Usuarios</h2>
    <a asp-page="Crear" class="btn btn-primary">+ Nuevo usuario</a>
</div>

@if (TempData["Mensaje"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Estado</th>
            <th>Creado</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var usuario in Model.Usuarios)
        {
            <tr class="@(usuario.Activo ? "" : "table-secondary text-muted")">
                <td>@usuario.Nombre</td>
                <td>
                    @if (usuario.Activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td>@usuario.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                <td class="text-end">
                    <a asp-page="Editar" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    @if (usuario.Activo)
                    {
                        <form method="post" asp-page-handler="Baja" asp-route-id="@usuario.Id" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('¿Dar de baja a @usuario.Nombre? Se caducarán todos sus permisos activos.')">
                                Dar de baja
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
