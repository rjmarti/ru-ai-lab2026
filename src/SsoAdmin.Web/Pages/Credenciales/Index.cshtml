@page
@model SsoAdmin.Web.Pages.Credenciales.IndexModel
@{
    ViewData["Title"] = "Credenciales";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Credenciales</h2>
    <a asp-page="Crear" class="btn btn-primary">+ Nueva credencial</a>
</div>

@if (TempData["Mensaje"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Username</th>
            <th>Emisor</th>
            <th>Usuario</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cred in Model.Credenciales)
        {
            <tr>
                <td>@cred.Username</td>
                <td>@cred.Emisor</td>
                <td>@cred.UsuarioNombre</td>
                <td class="text-end">
                    <form method="post" asp-page-handler="Eliminar" asp-route-id="@cred.Id" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('¿Eliminar esta credencial?')">
                            Eliminar
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
