@page
@model SsoAdmin.Web.Pages.Credenciales.CrearModel
@{
    ViewData["Title"] = "Nueva credencial";
}

<h2>Nueva credencial</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row">
    <div class="col-md-5">
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.UsuarioId" class="form-label">Usuario</label>
                <select asp-for="Input.UsuarioId" asp-items="Model.UsuariosItems" class="form-select">
                    <option value="">— Seleccionar —</option>
                </select>
                <span asp-validation-for="Input.UsuarioId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Username" class="form-label">Username</label>
                <input asp-for="Input.Username" class="form-control" />
                <span asp-validation-for="Input.Username" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Emisor" class="form-label">Emisor</label>
                <input asp-for="Input.Emisor" class="form-control" placeholder="google, azure, etc." />
                <span asp-validation-for="Input.Emisor" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
