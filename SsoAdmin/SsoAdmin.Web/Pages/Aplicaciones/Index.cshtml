@page
@model SsoAdmin.Web.Pages.Aplicaciones.IndexModel
@{ ViewData["Title"] = "Aplicaciones"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Aplicaciones</h2>
    <a asp-page="Create" class="btn btn-primary">+ Nueva aplicación</a>
</div>

@if (TempData["Mensaje"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>#</th><th>Nombre</th><th>URL</th><th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model.Aplicaciones)
        {
            <tr>
                <td>@a.Id</td>
                <td>@a.Name</td>
                <td><a href="@a.Url" target="_blank">@a.Url</a></td>
                <td>
                    <a asp-page="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                    <form method="post" asp-page-handler="Eliminar" asp-route-id="@a.Id" class="d-inline"
                          onsubmit="return confirm('¿Eliminar la aplicación @a.Name?')">
                        <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
