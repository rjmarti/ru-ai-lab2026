@page
@model SsoAdmin.Web.Pages.Credenciales.IndexModel
@{ ViewData["Title"] = "Credenciales"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Credenciales</h2>
    <a asp-page="Create" class="btn btn-primary">+ Nueva credencial</a>
</div>

@if (TempData["Mensaje"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>#</th><th>Username</th><th>Emisor</th><th>Usuario</th><th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Credenciales)
        {
            <tr>
                <td>@c.Id</td>
                <td>@c.Username</td>
                <td>@c.Emisor</td>
                <td>@c.UsuarioNombre</td>
                <td>
                    <form method="post" asp-page-handler="Eliminar" asp-route-id="@c.Id" class="d-inline"
                          onsubmit="return confirm('¿Eliminar la credencial @c.Username?')">
                        <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
